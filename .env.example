# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...       # from @BotFather
TELEGRAM_API_ID=12345                       # from https://my.telegram.org
TELEGRAM_API_HASH=abcdef1234567890abcdef    # from https://my.telegram.org

# Local Bot API server
TELEGRAM_BOT_API_URL=http://telegram-bot-api:8081

# Redis
REDIS_URL=redis://redis:6379/0

# Downloads
DOWNLOAD_DIR=/app/downloads
MAX_FILE_SIZE_MB=2000          # telegram-bot-api local limit
MAX_CONCURRENT_DOWNLOADS=3     # max simultaneous worker threads
DOWNLOAD_TIMEOUT=1800          # 30 min timeout per download

# Optional
ALLOWED_USERS=                 # comma-separated Telegram user IDs; empty = public
LOG_LEVEL=INFO
